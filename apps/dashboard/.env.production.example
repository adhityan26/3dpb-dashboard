# ── Database ─────────────────────────────────────────────────────────────────
# Persistent SQLite file inside the Docker volume mount.
DATABASE_URL="file:./data/prod.db"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 48
NEXTAUTH_SECRET=GANTI_DENGAN_RANDOM_STRING_PANJANG
# Set to your Synology IP or domain
NEXTAUTH_URL=http://192.168.88.XXX:3000
AUTH_TRUST_HOST=true

# ── Shopee Open Platform ─────────────────────────────────────────────────────
SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key
# Production URL (for sandbox use: https://partner.test-stable.shopeemobile.com)
SHOPEE_BASE_URL=https://partner.shopeemobile.com

# ── Notifications Background Poller ──────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
INTERNAL_NOTIFICATION_SECRET=GANTI_DENGAN_RANDOM_HEX_STRING

# ── Mock Mode (disable for production) ───────────────────────────────────────
# SHOPEE_MOCK_ADS=false
# SHOPEE_MOCK_PRODUCTS=false
# SHOPEE_MOCK_ANALYTICS=false
