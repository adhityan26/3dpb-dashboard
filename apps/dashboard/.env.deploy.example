# Copy file ini ke .env.deploy dan isi nilainya
# .env.deploy TIDAK boleh di-commit ke git

# Database
DATABASE_URL=file:./data/prod.db

# Auth
NEXTAUTH_URL=https://dashboard.3dprintingbandung.my.id
NEXTAUTH_SECRET=ganti_dengan_random_string_panjang

# Shopee API
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_BASE_URL=https://openplatform.shopee.com

# Feature flags (true/false)
SHOPEE_MOCK_ADS=false
SHOPEE_MOCK_ANALYTICS=false

# Misc
AUTH_TRUST_HOST=true
INTERNAL_NOTIFICATION_SECRET=ganti_dengan_random_string

# Override Docker target (opsional, default: tcp://192.168.88.113:2375)
# Untuk cloud nanti, ganti ke:
# DOCKER_HOST=ssh://user@your-server-ip
# DOCKER_HOST=tcp://your-server-ip:2375
# DOCKER_HOST=unix:///var/run/docker.sock  (kalau deploy dari server itu sendiri)
# DOCKER_HOST=tcp://192.168.88.113:2375

# MinIO
MINIO_ENDPOINT=http://192.168.88.18:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=ganti_dengan_secret_key
MINIO_BUCKET=lamp-orders

# STL Service (runs as sidecar container, built from services/stl-service/)
STL_SERVICE_URL=http://stl-service:8001
STL_SERVICE_TOKEN=<shared-secret-between-nextjs-and-python>

# Sanity CMS (landing page content)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
SANITY_WRITE_TOKEN=
