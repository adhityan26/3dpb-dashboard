generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model LabelStatus {
  orderId   String    @id
  printed   Boolean   @default(false)
  printedAt DateTime?
  printedBy String?
}

model ProductHpp {
  productId String       @id
  hpp       Float?
  variants  VariantHpp[]
}

model VariantHpp {
  variantId String     @id
  productId String
  hpp       Float?
  product   ProductHpp @relation(fields: [productId], references: [productId])
}

model NotificationLog {
  id       String   @id @default(cuid())
  alertKey String
  channel  String
  sentAt   DateTime @default(now())
  message  String

  @@index([alertKey, sentAt])
}

model ProductStatusSnapshot {
  productId String   @id
  status    String
  updatedAt DateTime @updatedAt
}

model FilamentCatalog {
  id         String   @id @default(cuid())
  brand      String
  material   String
  colorName  String
  colorHex   String
  syncedAt   DateTime @default(now())
  spools     Spool[]
  amsSlots   AmsSlot[]
  slotAlternatives AmsSlotAlternative[]

  @@unique([brand, material, colorName])
  @@index([brand])
}

model Printer {
  id        String   @id @default(cuid())
  name      String
  model     String   @default("")
  isActive  Boolean  @default(true)
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Spool {
  id              String           @id @default(cuid())
  catalogId       String?
  catalog         FilamentCatalog? @relation(fields: [catalogId], references: [id])
  brand           String
  material        String
  colorName       String
  colorHex        String
  status          String           @default("new")  // new|full|mid|low|empty
  barcode         String           @unique @default(cuid())
  nfcTagId        String?          @unique
  notes           String           @default("")
  hargaBeli       Float?           // effective purchase price per roll (from PO, incl. ongkir share)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  amsSlots        AmsSlot[]
  spoolmanSpool   SpoolmanSpool?
}

// ── Spoolman-compatible tables (for MrBambuSpoolPal Android app integration) ──

model SpoolmanVendor {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  comment          String             @default("")
  emptySpoolWeight Float?
  externalId       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  filaments        SpoolmanFilament[]
}

model SpoolmanFilament {
  id          Int              @id @default(autoincrement())
  externalId  String?          @unique   // Bambu DB ID e.g. "GFA00"
  name        String
  material    String           @default("")
  diameter    Float            @default(1.75)
  density     Float            @default(1.24)
  weight      Float?
  spoolWeight Float?
  colorHex    String?
  vendorId    Int?
  vendor      SpoolmanVendor?  @relation(fields: [vendorId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  spools      SpoolmanSpool[]
}

model SpoolmanSpool {
  id            Int               @id @default(autoincrement())
  filamentId    Int
  filament      SpoolmanFilament  @relation(fields: [filamentId], references: [id])
  lotNr         String?           @unique   // NFC tray UID from Bambu tag
  initialWeight Float?
  usedWeight    Float             @default(0)
  firstUsed     DateTime?
  lastUsed      DateTime?
  spoolId       String?           @unique   // FK to our Spool
  spool         Spool?            @relation(fields: [spoolId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model AmsSlot {
  id            String              @id @default(cuid())
  productType   String              // swoosh|clickers
  variantName   String
  slotNumber    Int                 // 1–8
  filamentName  String              // display name from CSV
  spoolId       String?
  spool         Spool?              @relation(fields: [spoolId], references: [id])
  catalogId     String?             // auto-matched from SpoolmanDB catalog
  catalog       FilamentCatalog?    @relation(fields: [catalogId], references: [id])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  alternatives  AmsSlotAlternative[]

  @@unique([productType, variantName, slotNumber])
  @@index([productType])
  @@index([spoolId])
  @@index([catalogId])
}

model AmsSlotAlternative {
  id         String           @id @default(cuid())
  slotId     String
  slot       AmsSlot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  type       String           // "specific" | "general"
  catalogId  String?
  catalog    FilamentCatalog? @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  brand      String?
  material   String?
  createdAt  DateTime         @default(now())

  @@index([slotId])
}

model KalkulasiHarga {
  id                String   @id @default(cuid())
  nama              String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  batch             Int      @default(1)
  marginTier        String   @default("A")
  hargaShopeeAktual  Float?
  hargaOfflineAktual Float?
  packingType       String?
  gantunganType     String?
  switchQty         Int      @default(0)
  hasLabel          Boolean  @default(false)
  hppProduksi       Float    @default(0)
  hppKomponen       Float    @default(0)
  hppTotal          Float    @default(0)
  floorPrice        Float    @default(0)
  offlineA          Float    @default(0)
  offlineB          Float    @default(0)
  offlineC          Float    @default(0)
  shopeeA           Float    @default(0)
  shopeeB           Float    @default(0)
  shopeeC           Float    @default(0)
  resellerStd       Float    @default(0)
  resellerBulk      Float    @default(0)
  marginOfflineA    Float    @default(0)
  marginShopeeA     Float    @default(0)
  status            String   @default("TIDAK_DISET")
  // Helm/Topeng fields — default "SIMPLE"/"RAW" agar backward-compatible
  produktType       String  @default("SIMPLE")   // "SIMPLE" | "HELM"
  finishType        String  @default("RAW")       // "RAW" | "FINISHING"
  jamSanding        Float   @default(0)           // Preparer hours (sanding + magnet)
  jamPainting       Float   @default(0)           // Finisher hours (painting)
  jamAssembly       Float   @default(0)           // Preparer hours (assembly)
  flatFinishingCost Float   @default(0)           // cat, primer, consumables flat
  hppFinishing      Float   @default(0)           // computed: labor + consumables
  plates               KalkulasiPlate[]
  komponenKustom       KomponenKustom[]
  produkLinks              KalkulasiProduk[]
  produkInternalLinks      ProdukInternal[]
  produkInternalShopeeLinks ProdukInternalShopeeLink[]
}

model KalkulasiPlate {
  id                   String         @id @default(cuid())
  kalkulasiId          String
  kalkulasi            KalkulasiHarga @relation(fields: [kalkulasiId], references: [id], onDelete: Cascade)
  urutan               Int
  namaPart             String?
  tipe                 String         @default("FDM")  // legacy single-material
  printer              String?
  gramasi              Float                            // legacy single-material gramasi
  materialsJson        String?                          // JSON: FilamentEntry[] for multi-material
  durasiJam            Float
  filamentHargaId      String?                          // FK to FilamentHarga (single-material override)
  filamentHargaPerGram Float?                           // cached rate at time of save
}

model KomponenKustom {
  id          String         @id @default(cuid())
  kalkulasiId String
  kalkulasi   KalkulasiHarga @relation(fields: [kalkulasiId], references: [id], onDelete: Cascade)
  nama        String
  harga       Float
  qty         Int            @default(1)
}

model KalkulasiProduk {
  id           String         @id @default(cuid())
  kalkulasiId  String
  kalkulasi    KalkulasiHarga @relation(fields: [kalkulasiId], references: [id], onDelete: Cascade)
  shopeeItemId String?
  namaManual   String?
  isPrimary    Boolean        @default(false)
}

model FilamentHarga {
  id           String @id @default(cuid())
  brand        String
  material     String
  hargaPerGram Float
  spoolCount   Int    @default(0)
  @@unique([brand, material])
}

model ResinHarga {
  id           String @id @default(cuid())
  brand        String
  grade        String
  hargaPerGram Float
  @@unique([brand, grade])
}

model ProdukInternal {
  id                 String                     @id @default(cuid())
  nama               String
  deskripsi          String?
  kategori           String?
  tags               String?                    // comma-separated
  sourceModel        String?                    // URL, folder path, or free text
  imageUrl           String?                    // local: /api/images/katalog/[id].jpg
  primaryKalkulasiId String?
  primaryKalkulasi   KalkulasiHarga?            @relation(fields: [primaryKalkulasiId], references: [id], onDelete: SetNull)
  shopeeLinks        ProdukInternalShopeeLink[]
  history            ProdukHistory[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
}

model ProdukHistory {
  id               String         @id @default(cuid())
  produkInternalId String
  produkInternal   ProdukInternal @relation(fields: [produkInternalId], references: [id], onDelete: Cascade)
  tanggal          DateTime       @default(now())
  qty              Int
  catatan          String?
  kalkulasiId      String?        // optional link to the kalkulasi used
  createdAt        DateTime       @default(now())
}

model ProdukInternalShopeeLink {
  id               String          @id @default(cuid())
  produkInternalId String
  produkInternal   ProdukInternal  @relation(fields: [produkInternalId], references: [id], onDelete: Cascade)
  shopeeItemId     String
  shopeeModelId    String?         // Shopee variant/model ID — null means product-level link
  kalkulasiId      String?         // Override kalkulasi for this specific variant
  kalkulasi        KalkulasiHarga? @relation(fields: [kalkulasiId], references: [id], onDelete: SetNull)
  namaProduk       String?         // Display name for this variant (e.g. "Flexi Shark S - Blue")

  @@unique([produkInternalId, shopeeItemId, shopeeModelId])
}

model Quotation {
  id            String           @id @default(cuid())
  nomor         String           @unique // e.g. INV-20260514-001
  buyerNama     String
  buyerContact  String?
  catatan       String?
  status        String           @default("DRAFT") // DRAFT|SENT|PAID|PARTIAL|CANCELLED
  tanggal       DateTime         @default(now())
  dueDate       DateTime?
  ongkir        Float            @default(0)
  diskonGlobal    Float   @default(0)
  diskonGlobalPct Float?
  shopeeOrderSn String?          // linked Shopee order
  items         QuotationItem[]
  payments      InvoicePayment[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model InvoicePayment {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  tanggal     DateTime  @default(now())
  jumlah      Float
  metode      String    @default("Transfer")
  catatan     String?
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

model QuotationItem {
  id               String      @id @default(cuid())
  quotationId      String
  quotation        Quotation   @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  produkInternalId String?
  namaProduk       String      // denormalized — survives if catalog entry deleted
  qty              Int         @default(1)
  hargaPerUnit     Float
  channelHarga     String      @default("marketplace") // "offline"|"marketplace"
  catatan          String?
  diskon    Float   @default(0)
  diskonPct Float?
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  nomor      String?             // vendor invoice number
  vendorNama String
  tanggal    DateTime            @default(now())
  status     String              @default("DRAFT") // DRAFT|ORDERED|RECEIVED|CANCELLED
  catatan    String?
  ongkir     Float               @default(0)
  items      PurchaseOrderItem[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model PurchaseOrderItem {
  id                String        @id @default(cuid())
  poId              String
  po                PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  namaProduct       String
  kode              String?
  qty               Float
  uom               String        @default("EA")
  harga             Float
  diskon            Float         @default(0)
  total             Float
  isFilament        Boolean       @default(false)
  brand             String?
  material          String?
  colorName         String?
  filamentCatalogId String?
}

model LightGeneratorOrder {
  id                  String   @id   // "LG-YYYYMMDD-XXXX"
  sanityDocId         String?         // Sanity _id stored at confirm time
  status              String   @default("submitted")
  statusNote          String?         // operator note, synced to Sanity
  customerName        String
  customerContact     String
  notesCustomer       String?
  configJson          String          // JSON blob: { size, shape, shapeRatio, shadowDiameter, shadowOffsetX, shadowOffsetY, supportStems }
  imagePath           String          // MinIO key: orders/{id}/input.{ext}
  configJsonOperator  String?         // operator override — null means use configJson
  stlPath             String?         // MinIO key: orders/{id}/casing.stl
  notesOperator       String?
  additionalImagePath String?         // MinIO key: orders/{id}/additional.png
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ShopeeProductIndex {
  itemId       String   @id
  name         String
  status       String   // "NORMAL" | "UNLIST"
  imageUrl     String?
  priceMin     Float    @default(0)
  priceMax     Float    @default(0)
  stockTotal   Int      @default(0)
  hasVariants  Boolean  @default(false)
  lastSyncedAt DateTime @default(now()) @updatedAt
}
