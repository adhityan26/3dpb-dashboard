generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model LabelStatus {
  orderId   String    @id
  printed   Boolean   @default(false)
  printedAt DateTime?
  printedBy String?
}

model ProductHpp {
  productId String       @id
  hpp       Float?
  variants  VariantHpp[]
}

model VariantHpp {
  variantId String     @id
  productId String
  hpp       Float?
  product   ProductHpp @relation(fields: [productId], references: [productId])
}
