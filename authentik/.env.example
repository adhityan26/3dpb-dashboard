# Copy ke .env dan isi nilainya
# File .env TIDAK boleh di-commit ke git

# Authentik version — cek release terbaru di:
# https://github.com/goauthentik/authentik/releases
AUTHENTIK_TAG=2024.12.3

# Secret key — generate dengan: openssl rand -base64 50
# JANGAN ganti secret key setelah pertama kali dipakai (akan invalidate semua session)
AUTHENTIK_SECRET_KEY=ganti_dengan_hasil_openssl_rand

# Database password — harus sama dengan yang dibuat di postgres
AUTHENTIK_DB_PASSWORD=authentik_db_password
